{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://3d-game-optimizer.local/schema/compatibility/v1",
  "title": "3D Game Compatibility Seed Schema",
  "type": "object",
  "required": [
    "version",
    "games"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "games": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/game"
      }
    }
  },
  "$defs": {
    "tierValue": {
      "type": "string",
      "enum": [
        "unsupported",
        "experimental",
        "playable",
        "optimized"
      ]
    },
    "review": {
      "type": "object",
      "required": [
        "summary",
        "confidence",
        "lastReviewedAt"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 5
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "lastReviewedAt": {
          "type": "string",
          "format": "date"
        }
      },
      "additionalProperties": false
    },
    "game": {
      "type": "object",
      "required": [
        "id",
        "title",
        "steamAppId",
        "steamTags",
        "tiersByVendor",
        "review"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "title": {
          "type": "string",
          "minLength": 2
        },
        "steamAppId": {
          "type": "integer",
          "minimum": 1
        },
        "steamTags": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "tiersByVendor": {
          "type": "object",
          "required": [
            "acer",
            "samsung",
            "nvidia",
            "generic"
          ],
          "properties": {
            "acer": {
              "$ref": "#/$defs/tierValue"
            },
            "samsung": {
              "$ref": "#/$defs/tierValue"
            },
            "nvidia": {
              "$ref": "#/$defs/tierValue"
            },
            "generic": {
              "$ref": "#/$defs/tierValue"
            }
          },
          "additionalProperties": false
        },
        "review": {
          "$ref": "#/$defs/review"
        },
        "vrCapability": {
          "type": "string",
          "enum": [
            "none",
            "nativeVr",
            "uevrCompatible"
          ]
        },
        "steamVrLaunchOptions": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
