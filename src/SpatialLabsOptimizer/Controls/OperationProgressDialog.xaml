<ContentDialog
    x:Class="SpatialLabsOptimizer.Controls.OperationProgressDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Operation in progress"
    PrimaryButtonText="Cancel"
    DefaultButton="Primary">
    <StackPanel Spacing="12" MinWidth="360">
        <TextBlock x:Name="TitleBlock" FontWeight="SemiBold" />
        <TextBlock x:Name="StepBlock" TextWrapping="Wrap" />
        <ProgressBar x:Name="ProgressBar" />
        <TextBlock x:Name="DetailBlock" Opacity="0.7" FontSize="12" />
    </StackPanel>
</ContentDialog>
