<Page
    x:Class="SpatialLabsOptimizer.Views.GameLibraryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:SpatialLabsOptimizer.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:library="using:SpatialLabsOptimizer.Infrastructure.Library"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:SpatialLabsOptimizer.ViewModels"
    xmlns:views="using:SpatialLabsOptimizer.Views"
    x:DataType="views:GameLibraryView"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:CoverPathToImageConverter x:Key="CoverConverter" />
    </Page.Resources>
    <Grid Padding="16" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold" Text="Library" />
            <Button Command="{x:Bind ViewModel.RefreshLibraryCommand}" Content="Refresh library" Style="{StaticResource AppButtonStyle}" ToolTipService.ToolTip="Re-check Steam installs and reload from cache" />
            <Button Command="{x:Bind ViewModel.RefreshCoverArtCommand}" Content="Refresh cover art" Style="{StaticResource AppButtonStyle}" ToolTipService.ToolTip="Download missing cover images only" />
            <Button Command="{x:Bind ViewModel.OpenCatalogCommand}" Content="Browse catalog" Style="{StaticResource AppButtonStyle}" VerticalAlignment="Center" />
            <TextBlock VerticalAlignment="Center" Opacity="0.7" Text="{x:Bind ViewModel.WarmStartStatus, Mode=OneWay}" />
        </StackPanel>
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ComboBox Width="180" Header="Sort by" SelectedIndex="{x:Bind ViewModel.SortModeIndex, Mode=TwoWay}">
                    <ComboBoxItem Content="Game Rank" />
                    <ComboBoxItem Content="Players Online" />
                    <ComboBoxItem Content="Steam Reviews" />
                    <ComboBoxItem Content="Name" />
                    <ComboBoxItem Content="Genre" />
                </ComboBox>
                <ComboBox Width="200" Header="Min 3D quality" SelectedIndex="{x:Bind ViewModel.MinRank3DScoreIndex, Mode=TwoWay}" VerticalAlignment="Bottom">
                    <ComboBoxItem Content="Any" />
                    <ComboBoxItem Content="Experimental (26+)" />
                    <ComboBoxItem Content="Playable (42+)" />
                    <ComboBoxItem Content="Optimized (58+)" />
                    <ComboBoxItem Content="Native (72+)" />
                    <ComboBoxItem Content="Ultra (88+)" />
                </ComboBox>
                <ComboBox Width="200" Header="Smart collection" SelectedIndex="{x:Bind ViewModel.SmartCollectionIndex, Mode=TwoWay}" VerticalAlignment="Bottom">
                    <ComboBoxItem Content="None" />
                    <ComboBoxItem Content="Favorites + tier" />
                    <ComboBoxItem Content="Never played in 3D" />
                    <ComboBoxItem Content="Local only" />
                </ComboBox>
                <ComboBox Width="160" Header="Preferred output" SelectedValue="{x:Bind ViewModel.PreferredOutput, Mode=TwoWay}" SelectedValuePath="Tag" VerticalAlignment="Bottom">
                    <ComboBoxItem Content="Auto" Tag="Auto" />
                    <ComboBoxItem Content="Monitor" Tag="Monitor" />
                    <ComboBoxItem Content="Headset" Tag="Headset" />
                </ComboBox>
                <Button VerticalAlignment="Bottom" Command="{x:Bind ViewModel.SaveOutputCommand}" Content="Save output" Style="{StaticResource AppButtonStyle}" />
                <CheckBox VerticalAlignment="Bottom" Content="Favorites" IsChecked="{x:Bind ViewModel.ShowFavoritesOnly, Mode=TwoWay}" />
                <CheckBox VerticalAlignment="Bottom" Content="Local" IsChecked="{x:Bind ViewModel.ShowLocalOnly, Mode=TwoWay}" />
                <CheckBox VerticalAlignment="Bottom" Content="Why not ready?" IsChecked="{x:Bind ViewModel.ShowWhyNotReady, Mode=TwoWay}" />
                <CheckBox VerticalAlignment="Bottom" Content="3D Ultra / Native" IsChecked="{x:Bind ViewModel.FilterUltraNative, Mode=TwoWay}" />
                <CheckBox VerticalAlignment="Bottom" Content="TrueGame" IsChecked="{x:Bind ViewModel.FilterTrueGame, Mode=TwoWay}" />
                <CheckBox VerticalAlignment="Bottom" Content="UEVR" IsChecked="{x:Bind ViewModel.FilterUevr, Mode=TwoWay}" />
                <CheckBox VerticalAlignment="Bottom" Content="3D Vision" IsChecked="{x:Bind ViewModel.Filter3DVision, Mode=TwoWay}" />
            </StackPanel>
        </ScrollViewer>
        <Grid x:Name="LibraryContentGrid" Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition MinHeight="160" Height="*" />
                <RowDefinition Height="8" />
                <RowDefinition MinHeight="80" MaxHeight="480" Height="180" />
            </Grid.RowDefinitions>
            <GridView
                x:Name="GamesGrid"
                AutomationProperties.AutomationId="GameLibrary_Grid"
                IsItemClickEnabled="True"
                ItemClick="GamesGrid_ItemClick"
                ItemsSource="{x:Bind ViewModel.Games, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedGame, Mode=TwoWay}"
                SelectionMode="Single">
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="ContextFlyout">
                            <Setter.Value>
                                <MenuFlyout>
                                    <MenuFlyoutItem Click="PlayContext_Click" Tag="3d" Text="Play in 3D" />
                                    <MenuFlyoutItem Click="PlayContext_Click" Tag="vr" Text="Play in VR" />
                                    <MenuFlyoutItem Click="OpenDetailContext_Click" Text="Details…" />
                                </MenuFlyout>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="library:GameLibraryItemViewModel">
                        <Grid Width="180" Height="280" Padding="8" Background="{StaticResource Brush.SurfaceAlt}" CornerRadius="8">
                            <StackPanel Spacing="4">
                                <Grid Height="200" Background="{StaticResource Brush.Surface}" CornerRadius="4">
                                    <Image
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Source="{x:Bind CoverImageKey, Converter={StaticResource CoverConverter}}"
                                        Stretch="Uniform" />
                                </Grid>
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" />
                                <TextBlock FontSize="11" Opacity="0.7" Text="{x:Bind StatusDisplay}" />
                                <TextBlock FontSize="11" FontWeight="SemiBold" Text="{x:Bind CompatibilityBadge}" />
                                <TextBlock
                                    FontSize="11"
                                    Opacity="0.85"
                                    Text="{x:Bind GameRankDisplay}"
                                    ToolTipService.ToolTip="{x:Bind GameRankTooltip, Mode=OneWay}" />
                                <TextBlock FontSize="11" Opacity="0.75" Text="{x:Bind SourceBadges}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
            <Border
                Grid.Row="1"
                Height="8"
                HorizontalAlignment="Stretch"
                Background="{StaticResource Brush.SurfaceAlt}"
                ManipulationMode="TranslateY"
                PointerMoved="RecentLaunchGrip_PointerMoved"
                PointerPressed="RecentLaunchGrip_PointerPressed"
                PointerReleased="RecentLaunchGrip_PointerReleased"
                ToolTipService.ToolTip="Drag to resize recent launches" />
            <Grid
                Grid.Row="2"
                Padding="0,8,0,0"
                Background="{StaticResource Brush.SurfaceAlt}"
                CornerRadius="8"
                RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock FontWeight="SemiBold" Opacity="0.85" Text="Recent launches" />
                <ListView
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.RecentLaunches, Mode=OneWay}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:RecentLaunchItemViewModel">
                            <Grid MinHeight="36" Padding="4,6" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.7" Text="{x:Bind LaunchedAtDisplay}" />
                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Opacity="0.7" Text="{x:Bind ResultDisplay}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>
