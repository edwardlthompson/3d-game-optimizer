<Page
    x:Class="SpatialLabsOptimizer.Views.GameLibraryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:SpatialLabsOptimizer.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:CoverPathToImageConverter x:Key="CoverConverter" />
    </Page.Resources>
    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Ready to Play" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Content="Refresh" Click="Refresh_Click" Style="{StaticResource AppButtonStyle}" ToolTipService.ToolTip="Reload library from cache" />
            <Button Content="Play in 3D" Click="Play_Click" Style="{StaticResource AppButtonStyle}" ToolTipService.ToolTip="Launch selected game in 3D" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <ComboBox x:Name="SortCombo" Header="Sort by" SelectionChanged="SortCombo_SelectionChanged" Width="200" />
            <TextBlock x:Name="WarmStartBlock" VerticalAlignment="Bottom" Opacity="0.7" />
        </StackPanel>
        <GridView
            x:Name="GamesGrid"
            Grid.Row="2"
            SelectionMode="Single"
            IsItemClickEnabled="True"
            SelectionChanged="GamesGrid_SelectionChanged">
            <GridView.ItemTemplate>
                <DataTemplate>
                    <Grid Width="180" Height="270" Background="{StaticResource Brush.SurfaceAlt}" CornerRadius="8" Padding="8">
                        <StackPanel Spacing="6">
                            <Image Source="{Binding CoverPath, Converter={StaticResource CoverConverter}}" Height="200" Stretch="UniformToFill" />
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding ReviewDisplay}" FontSize="11" Opacity="0.7" />
                            <TextBlock Text="{Binding PlayersDisplay}" FontSize="11" Opacity="0.7" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
