<Page
    x:Class="SpatialLabsOptimizer.Views.GameLibraryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:SpatialLabsOptimizer.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:library="using:SpatialLabsOptimizer.Infrastructure.Library"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:SpatialLabsOptimizer.ViewModels"
    xmlns:views="using:SpatialLabsOptimizer.Views"
    x:DataType="views:GameLibraryView"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:CoverPathToImageConverter x:Key="CoverConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>
    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Ready to Play" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Content="Refresh library" Command="{x:Bind ViewModel.RefreshLibraryCommand}" Style="{StaticResource AppButtonStyle}" ToolTipService.ToolTip="Re-check Steam installs and reload from cache" />
            <Button Content="Refresh cover art" Command="{x:Bind ViewModel.RefreshCoverArtCommand}" Style="{StaticResource AppButtonStyle}" ToolTipService.ToolTip="Download missing cover images only" />
            <Button Content="Play in 3D" Command="{x:Bind ViewModel.PlayCommand}" Style="{StaticResource AppButtonStyle}" ToolTipService.ToolTip="Launch selected game in 3D" />
            <Button Content="Play in VR" Command="{x:Bind ViewModel.PlayVrCommand}" Style="{StaticResource AppButtonStyle}" ToolTipService.ToolTip="Launch selected game in VR" />
            <Button Content="Pin" Command="{x:Bind ViewModel.PinCommand}" Style="{StaticResource AppButtonStyle}" />
            <Button Content="Unpin" Command="{x:Bind ViewModel.UnpinCommand}" Style="{StaticResource AppButtonStyle}" />
            <Button Content="Queue" Command="{x:Bind ViewModel.QueueCommand}" Style="{StaticResource AppButtonStyle}" />
            <Button Content="Play next" Command="{x:Bind ViewModel.PlayNextCommand}" Style="{StaticResource AppButtonStyle}" />
            <Button Content="Favorite" Command="{x:Bind ViewModel.ToggleFavoriteCommand}" Style="{StaticResource AppButtonStyle}" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <ComboBox Header="Sort by" SelectedIndex="{x:Bind ViewModel.SortModeIndex, Mode=TwoWay}" Width="200">
                <ComboBoxItem Content="3D Quality" />
                <ComboBoxItem Content="Players Online" />
                <ComboBoxItem Content="Steam Reviews" />
                <ComboBoxItem Content="Name" />
                <ComboBoxItem Content="Genre" />
            </ComboBox>
            <ComboBox Header="Preferred output" SelectedValue="{x:Bind ViewModel.PreferredOutput, Mode=TwoWay}" SelectedValuePath="Tag" Width="180">
                <ComboBoxItem Content="Auto" Tag="Auto" />
                <ComboBoxItem Content="Monitor" Tag="Monitor" />
                <ComboBoxItem Content="Headset" Tag="Headset" />
            </ComboBox>
            <Button Content="Save output" Command="{x:Bind ViewModel.SaveOutputCommand}" Style="{StaticResource AppButtonStyle}" VerticalAlignment="Bottom" />
            <CheckBox Content="Favorites only" IsChecked="{x:Bind ViewModel.ShowFavoritesOnly, Mode=TwoWay}" VerticalAlignment="Bottom" />
            <CheckBox Content="Local installs" IsChecked="{x:Bind ViewModel.ShowLocalOnly, Mode=TwoWay}" VerticalAlignment="Bottom" />
            <CheckBox Content="Why not ready?" IsChecked="{x:Bind ViewModel.ShowWhyNotReady, Mode=TwoWay}" VerticalAlignment="Bottom" />
            <Button Content="Browse catalog" Command="{x:Bind ViewModel.OpenCatalogCommand}" Style="{StaticResource AppButtonStyle}" VerticalAlignment="Bottom" />
            <TextBlock Text="{x:Bind ViewModel.WarmStartStatus, Mode=OneWay}" VerticalAlignment="Bottom" Opacity="0.7" />
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12">
            <CheckBox Content="3D Ultra / Native" IsChecked="{x:Bind ViewModel.FilterUltraNative, Mode=TwoWay}" VerticalAlignment="Bottom" />
            <CheckBox Content="TrueGame" IsChecked="{x:Bind ViewModel.FilterTrueGame, Mode=TwoWay}" VerticalAlignment="Bottom" />
            <CheckBox Content="UEVR" IsChecked="{x:Bind ViewModel.FilterUevr, Mode=TwoWay}" VerticalAlignment="Bottom" />
            <CheckBox Content="3D Vision" IsChecked="{x:Bind ViewModel.Filter3DVision, Mode=TwoWay}" VerticalAlignment="Bottom" />
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <ComboBox Header="Smart collection" SelectedIndex="{x:Bind ViewModel.SmartCollectionIndex, Mode=TwoWay}" Width="220" VerticalAlignment="Bottom">
                <ComboBoxItem Content="None" />
                <ComboBoxItem Content="Favorites + tier" />
                <ComboBoxItem Content="Never played in 3D" />
                <ComboBoxItem Content="Local only" />
            </ComboBox>
            <TextBox Header="Playlist name" Width="180" PlaceholderText="My session list" Text="{x:Bind ViewModel.PlaylistName, Mode=TwoWay}" />
            <Button Content="Save playlist" Command="{x:Bind ViewModel.SavePlaylistCommand}" Style="{StaticResource AppButtonStyle}" VerticalAlignment="Bottom" />
            <Button Content="Load playlist" Command="{x:Bind ViewModel.LoadPlaylistCommand}" Style="{StaticResource AppButtonStyle}" VerticalAlignment="Bottom" />
            <ComboBox Header="Saved playlists" ItemsSource="{x:Bind ViewModel.PlaylistNames, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.PlaylistName, Mode=TwoWay}" Width="200" VerticalAlignment="Bottom" />
        </StackPanel>
        <StackPanel Grid.Row="4" Spacing="8" Visibility="{x:Bind ViewModel.V2Enabled, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Community and co-op (v2)" FontWeight="SemiBold" />
            <TextBlock Text="Export selected titles for LAN parties, import allowlisted workshop presets, or start a hybrid co-op session." TextWrapping="Wrap" Opacity="0.8" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Import workshop presets" Command="{x:Bind ViewModel.V2WorkshopImportCommand}" Style="{StaticResource AppButtonStyle}" />
                <Button Content="Export LAN party list" Command="{x:Bind ViewModel.V2LanExportCommand}" Style="{StaticResource AppButtonStyle}" />
                <Button Content="Start hybrid co-op" Command="{x:Bind ViewModel.V2HybridSessionCommand}" Style="{StaticResource AppButtonStyle}" />
            </StackPanel>
            <TextBlock Text="{x:Bind ViewModel.V2StatusText, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.7" />
        </StackPanel>
        <StackPanel Grid.Row="5" Spacing="6">
            <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.HasSelectedGame, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{x:Bind ViewModel.SelectedGameTitle, Mode=OneWay}" FontWeight="SemiBold" FontSize="16" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Play in 3D" Command="{x:Bind ViewModel.PlayCommand}" Style="{StaticResource AppButtonStyle}" />
                    <Button Content="Play in VR" Command="{x:Bind ViewModel.PlayVrCommand}" Style="{StaticResource AppButtonStyle}" />
                </StackPanel>
            </StackPanel>
            <TextBlock Text="{x:Bind ViewModel.WhyNotReadyHint, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.8" />
            <TextBlock Text="{x:Bind ViewModel.SelectedRecommendedTools, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.75" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{x:Bind ViewModel.SelectedPresetFreshness, Mode=OneWay}" VerticalAlignment="Center" Opacity="0.8" />
                <Button Content="Refresh preset" Command="{x:Bind ViewModel.RefreshPresetCommand}" Style="{StaticResource AppButtonStyle}" />
            </StackPanel>
            <TextBox Header="Compatibility note (local only)" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Text="{x:Bind ViewModel.CompatibilityNote, Mode=TwoWay}" />
            <Button Content="Save note" Command="{x:Bind ViewModel.SaveCompatibilityNoteCommand}" Style="{StaticResource AppButtonStyle}" HorizontalAlignment="Left" />
        </StackPanel>
        <GridView
            x:Name="GamesGrid"
            Grid.Row="6"
            AutomationProperties.AutomationId="GameLibrary_Grid"
            IsItemClickEnabled="True"
            ItemsSource="{x:Bind ViewModel.Games, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedGame, Mode=TwoWay}"
            SelectionMode="Single">
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="ContextFlyout">
                        <Setter.Value>
                            <MenuFlyout>
                                <MenuFlyoutItem Click="PlayContext_Click" Tag="3d" Text="Play in 3D" />
                                <MenuFlyoutItem Click="PlayContext_Click" Tag="vr" Text="Play in VR" />
                            </MenuFlyout>
                        </Setter.Value>
                    </Setter>
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="library:GameLibraryItemViewModel">
                    <Grid Width="180" Height="310" Background="{StaticResource Brush.SurfaceAlt}" CornerRadius="8" Padding="8">
                        <StackPanel Spacing="6">
                            <Image Height="200" Source="{x:Bind CoverImageKey, Converter={StaticResource CoverConverter}}" Stretch="UniformToFill" />
                            <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="11" Opacity="0.7" Text="{x:Bind StatusDisplay}" />
                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="{x:Bind CompatibilityBadge}" />
                            <TextBlock FontSize="11" Opacity="0.75" Text="{x:Bind SourceBadges}" TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="11" Opacity="0.7" Text="{x:Bind PresetFreshness}" />
                            <TextBlock FontSize="11" Opacity="0.7" Text="{x:Bind ReviewDisplay}" />
                            <TextBlock FontSize="11" Opacity="0.7" Text="{x:Bind PlayersDisplay}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
        <StackPanel Grid.Row="7" Spacing="4">
            <TextBlock FontWeight="SemiBold" Text="Recent launches" />
            <ListView MinHeight="80" MaxHeight="120" ItemsSource="{x:Bind ViewModel.RecentLaunches, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:RecentLaunchItemViewModel">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="{x:Bind Title}" />
                            <TextBlock Opacity="0.7" Text="{x:Bind LaunchedAtDisplay}" />
                            <TextBlock Opacity="0.7" Text="{x:Bind ResultDisplay}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</Page>
