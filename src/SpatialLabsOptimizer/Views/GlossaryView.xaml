<Page
    x:Class="SpatialLabsOptimizer.Views.GlossaryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:SpatialLabsOptimizer.Converters"
    xmlns:viewmodels="using:SpatialLabsOptimizer.ViewModels"
    xmlns:views="using:SpatialLabsOptimizer.Views"
    x:DataType="views:GlossaryView">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>
    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="720">
            <TextBlock Text="Glossary" FontSize="28" FontWeight="SemiBold" />
            <TextBlock
                Text="Plain-language definitions for 3D gaming and compatibility terms used in this app."
                TextWrapping="Wrap"
                Opacity="0.8" />
            <TextBlock
                Text="{x:Bind ViewModel.LoadError, Mode=OneWay}"
                TextWrapping="Wrap"
                Foreground="{StaticResource Brush.Accent}"
                Visibility="{x:Bind ViewModel.HasLoadError, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
            <ItemsControl ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:GlossaryEntryViewModel">
                        <StackPanel Spacing="4" Margin="0,0,0,12">
                            <TextBlock Text="{x:Bind Term}" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind Definition}" TextWrapping="Wrap" Opacity="0.85" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
