<Page
    x:Class="SpatialLabsOptimizer.Views.LibrarySettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:SpatialLabsOptimizer.Views"
    x:DataType="views:LibrarySettingsView">
    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="820">
            <TextBlock Text="Library Settings" FontSize="28" FontWeight="SemiBold" />
            <TextBlock
                Text="Connect game stores and watch custom install folders. Credentials stay on your PC — nothing is uploaded."
                TextWrapping="Wrap"
                Opacity="0.8" />

            <Border Padding="16" Background="{StaticResource Brush.SurfaceAlt}" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Library summary" FontWeight="SemiBold" />
                    <TextBlock Text="{x:Bind ViewModel.StatsSummary, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.85" />
                    <Button Content="Refresh counts" Command="{x:Bind ViewModel.RefreshStatsCommand}" Style="{StaticResource AppButtonStyle}" />
                </StackPanel>
            </Border>

            <Border Padding="16" Background="{StaticResource Brush.SurfaceAlt}" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Steam" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock Text="Web API key + Steam ID64 fetch your owned catalog and validate the connection." TextWrapping="Wrap" Opacity="0.75" FontSize="12" />
                    <TextBox Header="Steam ID64" PlaceholderText="7656119…" Text="{x:Bind ViewModel.SteamId, Mode=TwoWay}" />
                    <PasswordBox x:Name="SteamKeyBox" PlaceholderText="Steam Web API key" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Test connection" Click="TestSteam_Click" Style="{StaticResource AppButtonStyle}" />
                        <Button Content="Get API key" Command="{x:Bind ViewModel.OpenSteamKeyHelpCommand}" Style="{StaticResource AppButtonStyle}" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.SteamStatus, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.85" />
                </StackPanel>
            </Border>

            <Border Padding="16" Background="{StaticResource Brush.SurfaceAlt}" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Epic Games" FontWeight="SemiBold" FontSize="16" />
                    <TextBox Header="Manifests folder" IsReadOnly="True" Text="{x:Bind ViewModel.EpicPath, Mode=OneWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Browse…" Click="BrowseEpic_Click" Style="{StaticResource AppButtonStyle}" />
                        <Button Content="Validate" Command="{x:Bind ViewModel.ValidateEpicCommand}" Style="{StaticResource AppButtonStyle}" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.EpicStatus, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.85" />
                    <TextBlock Text="Local install scan only — online catalog deferred per ADR-0004. See docs/PLATFORM_CONNECTIONS.md." TextWrapping="Wrap" Opacity="0.55" FontSize="12" />
                </StackPanel>
            </Border>

            <Border Padding="16" Background="{StaticResource Brush.SurfaceAlt}" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="GOG Galaxy" FontWeight="SemiBold" FontSize="16" />
                    <TextBox Header="Games folder" IsReadOnly="True" Text="{x:Bind ViewModel.GogPath, Mode=OneWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Browse…" Click="BrowseGog_Click" Style="{StaticResource AppButtonStyle}" />
                        <Button Content="Validate" Command="{x:Bind ViewModel.ValidateGogCommand}" Style="{StaticResource AppButtonStyle}" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.GogStatus, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.85" />
                    <TextBlock Text="Local install scan only — online catalog deferred per ADR-0004. See docs/PLATFORM_CONNECTIONS.md." TextWrapping="Wrap" Opacity="0.55" FontSize="12" />
                </StackPanel>
            </Border>

            <Border Padding="16" Background="{StaticResource Brush.SurfaceAlt}" CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Ubisoft Connect" FontWeight="SemiBold" FontSize="16" />
                    <TextBox Header="Configuration folder" IsReadOnly="True" Text="{x:Bind ViewModel.UbisoftPath, Mode=OneWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Browse…" Click="BrowseUbisoft_Click" Style="{StaticResource AppButtonStyle}" />
                        <Button Content="Validate" Command="{x:Bind ViewModel.ValidateUbisoftCommand}" Style="{StaticResource AppButtonStyle}" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.UbisoftStatus, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.85" />
                    <TextBlock Text="Local install scan only — online catalog deferred per ADR-0004. See docs/PLATFORM_CONNECTIONS.md." TextWrapping="Wrap" Opacity="0.55" FontSize="12" />
                </StackPanel>
            </Border>

            <TextBlock Text="Custom local folders" FontWeight="SemiBold" FontSize="16" Margin="0,8,0,0" />
            <TextBlock Text="Games installed outside store launchers." TextWrapping="Wrap" Opacity="0.75" FontSize="12" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Add folder" Click="AddFolder_Click" Style="{StaticResource AppButtonStyle}" />
                <Button Content="Remove selected" Command="{x:Bind ViewModel.RemoveSelectedFolderCommand}" Style="{StaticResource AppButtonStyle}" />
                <Button Content="Refresh scan" Command="{x:Bind ViewModel.RescanFoldersCommand}" Style="{StaticResource AppButtonStyle}" />
            </StackPanel>
            <ListView
                ItemsSource="{x:Bind ViewModel.FoldersList, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedFolder, Mode=TwoWay}"
                SelectionMode="Single"
                MinHeight="120"
                AutomationProperties.AutomationId="LibrarySettings_FolderList" />
            <TextBlock Text="{x:Bind ViewModel.FolderStatus, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.7" />
        </StackPanel>
    </ScrollViewer>
</Page>
