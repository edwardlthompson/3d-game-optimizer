<Page
    x:Class="SpatialLabsOptimizer.Views.Global3DSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:SpatialLabsOptimizer.Converters"
    xmlns:displays="using:SpatialLabsOptimizer.Infrastructure.Displays"
    xmlns:pcvr="using:SpatialLabsOptimizer.Infrastructure.Pcvr"
    xmlns:viewmodels="using:SpatialLabsOptimizer.ViewModels"
    xmlns:views="using:SpatialLabsOptimizer.Views"
    x:DataType="views:Global3DSettingsView">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>
    <ScrollViewer Padding="24,24,24,24">
        <StackPanel Spacing="12" HorizontalAlignment="Stretch">
            <TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Grouped global 3D, launch, and session preferences." TextWrapping="Wrap" Opacity="0.8" />

            <Expander x:Name="ToolchainExpander" Header="Toolchain &amp; display" IsExpanded="True" Style="{StaticResource SettingsExpanderStyle}">
                <views:ToolchainSetupPanel x:Name="ToolchainPanel" />
            </Expander>

            <Expander Header="Display &amp; depth" IsExpanded="True" Style="{StaticResource SettingsExpanderStyle}">
                <StackPanel Style="{StaticResource SettingsSectionContentStyle}">
                    <Slider Header="Depth" HorizontalAlignment="Stretch" Maximum="1" Minimum="0" StepFrequency="0.05" Value="{x:Bind ViewModel.Depth, Mode=TwoWay}" />
                    <Slider Header="Convergence" HorizontalAlignment="Stretch" Maximum="1" Minimum="0" StepFrequency="0.05" Value="{x:Bind ViewModel.Convergence, Mode=TwoWay}" />
                    <ComboBox Header="Theme" HorizontalAlignment="Stretch" MaxWidth="480" SelectedIndex="{x:Bind ViewModel.ThemeIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="System" Tag="system" />
                        <ComboBoxItem Content="Light" Tag="light" />
                        <ComboBoxItem Content="Dark" Tag="dark" />
                    </ComboBox>
                    <Button Command="{x:Bind ViewModel.ToggleViewingDistanceCoachCommand}" Content="Viewing distance coach…" Style="{StaticResource AppButtonStyle}" />
                    <views:ViewingDistanceCoachView x:Name="ViewingDistanceCoachPanel" Visibility="{x:Bind ViewModel.ShowViewingDistanceCoach, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>
            </Expander>

            <Expander Header="3D Display settings" IsExpanded="True" Style="{StaticResource SettingsExpanderStyle}">
                <StackPanel Style="{StaticResource SettingsSectionContentStyle}">
                    <ComboBox
                        DisplayMemberPath="FriendlyName"
                        Header="Launch target display"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.LaunchDisplayTargets, Mode=OneWay}"
                        MaxWidth="480"
                        SelectedItem="{x:Bind ViewModel.SelectedLaunchDisplay, Mode=TwoWay}" />
                    <TextBlock Opacity="0.7" Text="{x:Bind ViewModel.LaunchDisplayStatus, Mode=OneWay}" TextWrapping="Wrap" />
                    <ComboBox
                        DisplayMemberPath="Label"
                        Header="OpenXR runtime override"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.OpenXrRuntimeOptions, Mode=OneWay}"
                        MaxWidth="480"
                        SelectedItem="{x:Bind ViewModel.SelectedOpenXrRuntime, Mode=TwoWay}" />
                    <TextBlock Opacity="0.7" Text="{x:Bind ViewModel.OpenXrRuntimeStatus, Mode=OneWay}" TextWrapping="Wrap" />
                    <TextBlock FontSize="12" Opacity="0.65" Text="Launch target and OpenXR override apply to 3D and PCVR sessions." TextWrapping="Wrap" />
                </StackPanel>
            </Expander>

            <Expander Header="Launch safety" IsExpanded="True" Style="{StaticResource SettingsExpanderStyle}">
                <StackPanel Style="{StaticResource SettingsSectionContentStyle}">
                    <ToggleSwitch Header="Safe launch (no injectors)" IsOn="{x:Bind ViewModel.SafeLaunch, Mode=TwoWay}" OffContent="Off" OnContent="On" />
                    <ToggleSwitch Header="I use game trainers (WeMod, Wand, etc.)" IsOn="{x:Bind ViewModel.TrainerCoexistence, Mode=TwoWay}" OffContent="Off" OnContent="On" />
                    <ToggleSwitch Header="I use a mod manager (Vortex, Mod Organizer)" IsOn="{x:Bind ViewModel.ModManagerCoexistence, Mode=TwoWay}" OffContent="Off" OnContent="On" />
                    <ToggleSwitch Header="Simple mode UI" IsOn="{x:Bind ViewModel.SimpleMode, Mode=TwoWay}" OffContent="Off" OnContent="On" />
                    <TextBlock FontSize="12" Opacity="0.7" Text="{x:Bind ViewModel.DetectedToolsText, Mode=OneWay}" TextWrapping="Wrap" />
                    <Button Command="{x:Bind ViewModel.RefreshDetectedToolsCommand}" Content="Refresh detected tools" Style="{StaticResource AppButtonStyle}" />
                </StackPanel>
            </Expander>

            <Expander Header="Session profiles" IsExpanded="False" Style="{StaticResource SettingsExpanderStyle}" Visibility="{x:Bind ViewModel.SessionToolsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Style="{StaticResource SettingsSectionContentStyle}">
                    <TextBlock Opacity="0.8" Text="{x:Bind ViewModel.StreamerHotkeyText, Mode=OneWay}" TextWrapping="Wrap" />
                    <TextBlock Opacity="0.8" Text="{x:Bind ViewModel.StreamFriendlyText, Mode=OneWay}" TextWrapping="Wrap" />
                    <TextBox Header="Save current depth settings as…" HorizontalAlignment="Stretch" MaxWidth="480" PlaceholderText="LAN night profile" Text="{x:Bind ViewModel.SessionProfileName, Mode=TwoWay}" />
                    <ComboBox Header="Load saved session…" HorizontalAlignment="Stretch" ItemsSource="{x:Bind ViewModel.SessionProfileNames, Mode=OneWay}" MaxWidth="480" SelectedItem="{x:Bind ViewModel.SessionProfileName, Mode=TwoWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{x:Bind ViewModel.SaveSessionProfileCommand}" Content="Save profile" Style="{StaticResource AppButtonStyle}" />
                        <Button Command="{x:Bind ViewModel.LoadSessionProfileCommand}" Content="Load profile" Style="{StaticResource AppButtonStyle}" />
                    </StackPanel>
                    <TextBlock Opacity="0.7" Text="{x:Bind ViewModel.SessionProfileStatus, Mode=OneWay}" TextWrapping="Wrap" />
                </StackPanel>
            </Expander>

            <Expander Header="Integrations" IsExpanded="False" Style="{StaticResource SettingsExpanderStyle}" Visibility="{x:Bind ViewModel.V2PanelVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Style="{StaticResource SettingsSectionContentStyle}">
                    <TextBlock Opacity="0.8" Text="Enable optional integrations. Restart required after changes." TextWrapping="Wrap" />
                    <CheckBox Content="LAN session export" IsChecked="{x:Bind ViewModel.V2LanEnabled, Mode=TwoWay}" />
                    <CheckBox Content="Hybrid desktop + VR sessions" IsChecked="{x:Bind ViewModel.V2HybridEnabled, Mode=TwoWay}" />
                    <CheckBox Content="Epic / GOG library scan" IsChecked="{x:Bind ViewModel.V2EpicGogEnabled, Mode=TwoWay}" />
                    <TextBlock Foreground="{StaticResource Brush.Accent}" Opacity="0.85" Text="{x:Bind ViewModel.V2RestartNotice, Mode=OneWay}" TextWrapping="Wrap" Visibility="{x:Bind ViewModel.ShowV2RestartNotice, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>
            </Expander>

            <Expander Header="Advanced" IsExpanded="False" Style="{StaticResource SettingsExpanderStyle}">
                <StackPanel Style="{StaticResource SettingsSectionContentStyle}">
                    <Button Command="{x:Bind ViewModel.CachePresetsCommand}" Content="Cache top presets" Style="{StaticResource AppButtonStyle}" />
                    <TextBlock Opacity="0.7" Text="{x:Bind ViewModel.BulkPresetStatus, Mode=OneWay}" />
                    <Button Click="LibrarySettings_Click" Content="Library Settings" Style="{StaticResource AppButtonStyle}" />
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Per-game overrides" />
                        <TextBox Header="Steam App ID" HorizontalAlignment="Stretch" MaxWidth="480" PlaceholderText="570" Text="{x:Bind ViewModel.OverrideAppId, Mode=TwoWay}" />
                        <Slider Header="Override depth" HorizontalAlignment="Stretch" Maximum="1" Minimum="0" StepFrequency="0.05" Value="{x:Bind ViewModel.OverrideDepth, Mode=TwoWay}" />
                        <Slider Header="Override convergence" HorizontalAlignment="Stretch" Maximum="1" Minimum="0" StepFrequency="0.05" Value="{x:Bind ViewModel.OverrideConvergence, Mode=TwoWay}" />
                        <ComboBox Header="Platform override" HorizontalAlignment="Stretch" MaxWidth="480" SelectedIndex="{x:Bind ViewModel.OverridePlatformIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="Auto" Tag="" />
                            <ComboBoxItem Content="UEVR" Tag="Uevr" />
                            <ComboBoxItem Content="ReShade" Tag="ReShade" />
                            <ComboBoxItem Content="TrueGame" Tag="TrueGame" />
                        </ComboBox>
                        <Button Command="{x:Bind ViewModel.SaveOverrideCommand}" Content="Save override" Style="{StaticResource AppButtonStyle}" />
                        <TextBlock Opacity="0.7" Text="{x:Bind ViewModel.OverrideStatus, Mode=OneWay}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Config snapshots" />
                        <TextBlock FontSize="12" Opacity="0.75" Text="Restore per-game override settings captured before Play in 3D." TextWrapping="Wrap" />
                        <TextBox Header="Filter by Steam App ID (optional)" HorizontalAlignment="Stretch" MaxWidth="480" PlaceholderText="570" Text="{x:Bind ViewModel.SnapshotFilterAppId, Mode=TwoWay}" />
                        <ComboBox
                            DisplayMemberPath="Label"
                            Header="Saved snapshots"
                            HorizontalAlignment="Stretch"
                            ItemsSource="{x:Bind ViewModel.SnapshotItems, Mode=OneWay}"
                            MaxWidth="480"
                            SelectedItem="{x:Bind ViewModel.SelectedSnapshot, Mode=TwoWay}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{x:Bind ViewModel.RefreshSnapshotsCommand}" Content="Refresh list" Style="{StaticResource AppButtonStyle}" />
                            <Button Command="{x:Bind ViewModel.RestoreSnapshotCommand}" Content="Restore selected" Style="{StaticResource AppButtonStyle}" />
                        </StackPanel>
                        <TextBlock Opacity="0.7" Text="{x:Bind ViewModel.SnapshotStatus, Mode=OneWay}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.HdrPanelVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock FontWeight="SemiBold" Text="HDR handoff" />
                        <TextBlock Opacity="0.8" Text="{x:Bind ViewModel.HdrNoticeText, Mode=OneWay}" TextWrapping="Wrap" />
                        <Button Command="{x:Bind ViewModel.DisableHdrCommand}" Content="Disable HDR for 3D session" Style="{StaticResource AppButtonStyle}" />
                    </StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="Hardware benchmark" />
                    <TextBlock Opacity="0.8" Text="Optional ~30 second CPU benchmark refines performance tier." TextWrapping="Wrap" />
                    <Button Command="{x:Bind ViewModel.RunBenchmarkCommand}" Content="Run benchmark" Style="{StaticResource AppButtonStyle}" />
                    <TextBlock Opacity="0.7" Text="{x:Bind ViewModel.BenchmarkResult, Mode=OneWay}" />
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</Page>
