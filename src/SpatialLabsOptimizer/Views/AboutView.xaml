<Page
    x:Class="SpatialLabsOptimizer.Views.AboutView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:SpatialLabsOptimizer.Converters"
    xmlns:views="using:SpatialLabsOptimizer.Views"
    x:DataType="views:AboutView">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>
    <ScrollViewer Padding="24">
        <StackPanel Spacing="12" MaxWidth="640">
            <TextBlock Text="About 3D Game Optimizer" FontSize="28" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap" Text="Independent tool for glasses-free 3D PC gaming. Not affiliated with Acer, Samsung, NVIDIA, Valve, or other trademark holders. See docs/LEGAL.md and docs/TRADEMARKS.md." />
            <HyperlinkButton Content="Privacy policy" NavigateUri="https://github.com/edwardlthompson/3d-game-optimizer/blob/main/docs/PRIVACY.md" />
            <TextBlock Text="{x:Bind ViewModel.VersionText, Mode=OneWay}" Opacity="0.7" />

            <TextBlock Text="Updates" FontSize="20" FontWeight="SemiBold" Margin="0,12,0,0" />
            <InfoBar
                Severity="Warning"
                Title="Update pending restart"
                Message="The last update did not finish applying. Retry without re-downloading if the installer is already staged."
                IsOpen="{x:Bind ViewModel.IsRetryOpen, Mode=OneWay}"
                IsClosable="False">
                <InfoBar.ActionButton>
                    <Button Content="Retry update" Command="{x:Bind ViewModel.RetryUpdateCommand}" Style="{StaticResource AppButtonStyle}" />
                </InfoBar.ActionButton>
            </InfoBar>
            <ComboBox Header="Automatic update checks" SelectedIndex="{x:Bind ViewModel.UpdateIntervalIndex, Mode=TwoWay}" Width="320">
                <ComboBoxItem Content="Off" Tag="Off" />
                <ComboBoxItem Content="On startup" Tag="Startup" />
                <ComboBoxItem Content="Daily" Tag="Daily" />
                <ComboBoxItem Content="Weekly" Tag="Weekly" />
            </ComboBox>
            <TextBlock Text="{x:Bind ViewModel.InstallTypeText, Mode=OneWay}" Opacity="0.7" />
            <ComboBox Header="Install type override (advanced)" SelectedIndex="{x:Bind ViewModel.InstallTypeOverrideIndex, Mode=TwoWay}" Width="320">
                <ComboBoxItem Content="Auto-detect" Tag="" />
                <ComboBoxItem Content="Portable (zip)" Tag="Zip" />
                <ComboBoxItem Content="MSIX" Tag="Msix" />
                <ComboBoxItem Content="MSI" Tag="Msi" />
            </ComboBox>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Check now" Command="{x:Bind ViewModel.CheckUpdateCommand}" Style="{StaticResource AppButtonStyle}" />
                <Button Content="Update and restart" Command="{x:Bind ViewModel.ApplyUpdateCommand}" IsEnabled="{x:Bind ViewModel.IsApplyEnabled, Mode=OneWay}" Style="{StaticResource AppButtonStyle}" />
            </StackPanel>
            <HyperlinkButton
                Content="View release notes"
                Command="{x:Bind ViewModel.OpenReleaseNotesCommand}"
                Visibility="{x:Bind ViewModel.ShowReleaseNotes, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
            <TextBlock Text="{x:Bind ViewModel.UpdateStatusText, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.7" />

            <TextBlock Text="3D catalog sync" FontSize="20" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBlock TextWrapping="Wrap" Opacity="0.8" Text="Opt-in download of catalog-v2.json from GitHub Pages. Verified with SHA256 when a hash file is published." />
            <ComboBox Header="Automatic catalog checks" SelectedIndex="{x:Bind ViewModel.CatalogIntervalIndex, Mode=TwoWay}" Width="320">
                <ComboBoxItem Content="Off" />
                <ComboBoxItem Content="On startup" />
                <ComboBoxItem Content="Daily" />
                <ComboBoxItem Content="Weekly" />
            </ComboBox>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Check catalog now" Command="{x:Bind ViewModel.CheckCatalogCommand}" Style="{StaticResource AppButtonStyle}" />
                <HyperlinkButton Content="Browse catalog online" NavigateUri="https://edwardlthompson.github.io/3d-game-optimizer/catalog/" />
            </StackPanel>
            <TextBlock Text="{x:Bind ViewModel.CatalogStatusText, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.7" />

            <TextBlock Text="Support development" FontSize="20" FontWeight="SemiBold" Margin="0,12,0,0" />
            <TextBlock TextWrapping="Wrap" Opacity="0.8" Text="Enjoying 3D Game Optimizer? Voluntary tips help support development. Donations are optional and not affiliated with Venmo or PayPal." />
            <HyperlinkButton Content="Support on Venmo" NavigateUri="https://venmo.com/code?user_id=1857304970395648420" />
        </StackPanel>
    </ScrollViewer>
</Page>
