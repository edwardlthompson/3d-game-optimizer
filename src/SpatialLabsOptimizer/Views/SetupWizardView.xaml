<Page
    x:Class="SpatialLabsOptimizer.Views.SetupWizardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:SpatialLabsOptimizer.Views"
    xmlns:viewmodels="using:SpatialLabsOptimizer.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:DataType="viewmodels:SetupWizardViewModel">
    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Setup Wizard" FontSize="28" FontWeight="SemiBold" />
        <StackPanel Grid.Row="1" Spacing="16">
            <StackPanel x:Name="DisclaimerPanel" Spacing="8">
                <TextBlock Text="Legal consent" FontSize="18" FontWeight="SemiBold" />
                <TextBlock TextWrapping="Wrap" Text="3D Game Optimizer is an independent tool. By continuing, you accept silent installation of third-party toolchain components per docs/LEGAL.md." />
                <CheckBox x:Name="DisclaimerCheck" AutomationProperties.AutomationId="SetupWizard_DisclaimerCheck" Content="I accept the toolchain EULA and legal disclaimers" Checked="DisclaimerCheck_Changed" Unchecked="DisclaimerCheck_Changed" />
                <CheckBox x:Name="OfflineCheck" Content="Offline onboarding (skip network downloads)" Checked="OfflineCheck_Changed" Unchecked="OfflineCheck_Changed" />
            </StackPanel>
            <InfoBar x:Name="MuxInfoBar" Severity="Warning" IsOpen="False" Title="Dual-GPU detected" />
            <TextBlock x:Name="ViewingDistanceBlock" TextWrapping="Wrap" Opacity="0.85" />
            <views:ViewingDistanceCoachView x:Name="ViewingDistanceCoach" Visibility="Collapsed" />
            <Button x:Name="ViewingDistanceCoachButton" Content="Viewing distance coach" Click="ViewingDistanceCoach_Click" Style="{StaticResource AppButtonStyle}" HorizontalAlignment="Left" />
            <views:ManualDisplayPickerView x:Name="DisplayPicker" Visibility="Collapsed" />
            <TextBlock x:Name="RequiredToolsHeader" Text="Required toolchain for selected display" FontWeight="SemiBold" Visibility="Collapsed" />
            <ItemsControl x:Name="RequiredToolsPanel" Visibility="Collapsed">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:ToolInstallItemViewModel">
                        <Grid ColumnSpacing="12" Padding="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind StatusGlyph}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind StatusLabel}" FontSize="12" Opacity="0.75" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ProgressBar x:Name="InstallProgressBar" Minimum="0" Maximum="100" Visibility="Collapsed" />
            <ListView x:Name="InstallLogList" MaxHeight="120" Visibility="Collapsed" />
            <TextBlock x:Name="StatusBlock" TextWrapping="Wrap" />
            <TextBlock x:Name="BenchmarkResultBlock" TextWrapping="Wrap" Opacity="0.85" />
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <Button AutomationProperties.AutomationId="SetupWizard_Continue" Content="Continue" Click="Continue_Click" Style="{StaticResource AppButtonStyle}" />
            <Button x:Name="BenchmarkButton" AutomationProperties.AutomationId="SetupWizard_Benchmark" Content="Run Benchmark (optional)" Click="Benchmark_Click" Style="{StaticResource AppButtonStyle}" ToolTipService.ToolTip="Optional ~30 second local CPU benchmark" />
        </StackPanel>
    </Grid>
</Page>
