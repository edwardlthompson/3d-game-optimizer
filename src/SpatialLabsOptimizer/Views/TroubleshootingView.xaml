<Page
    x:Class="SpatialLabsOptimizer.Views.TroubleshootingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:SpatialLabsOptimizer.Converters"
    xmlns:viewmodels="using:SpatialLabsOptimizer.ViewModels"
    xmlns:views="using:SpatialLabsOptimizer.Views"
    x:DataType="views:TroubleshootingView">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>
    <ScrollViewer Padding="24">
        <StackPanel Spacing="12" MaxWidth="640">
            <TextBlock Text="Troubleshooting" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Export a redacted diagnostic bundle or view structured error codes (3DGO-####)." TextWrapping="Wrap" Opacity="0.8" />
            <Button Content="Export diagnostic bundle" Command="{x:Bind ViewModel.ExportDiagnosticsCommand}" Style="{StaticResource AppButtonStyle}" />
            <TextBox Header="Steam App ID for dry run" PlaceholderText="e.g. 1091500" Text="{x:Bind ViewModel.DryRunAppId, Mode=TwoWay}" />
            <Button Content="Simulate Play in 3D (dry run)" Command="{x:Bind ViewModel.DryRunCommand}" Style="{StaticResource AppButtonStyle}" />
            <Button Content="Export seed contribution JSON" Command="{x:Bind ViewModel.SeedExportCommand}" Style="{StaticResource AppButtonStyle}" />
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.7" />
            <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.V2Enabled, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="v2 tools (SPATIALLABS_ENABLE_V2=true)" FontWeight="SemiBold" />
                <TextBlock Text="Select library titles for LAN export or hybrid co-op session." TextWrapping="Wrap" Opacity="0.8" />
                <ItemsControl ItemsSource="{x:Bind ViewModel.ExportItems, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:TroubleshootingExportItemViewModel">
                            <CheckBox Content="{x:Bind Title}" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBox Header="Workshop URL (optional)" PlaceholderText="Allowlisted HTTPS URL" Text="{x:Bind ViewModel.WorkshopUrl, Mode=TwoWay}" />
                <Button Content="Import workshop presets" Command="{x:Bind ViewModel.WorkshopImportCommand}" Style="{StaticResource AppButtonStyle}" />
                <Button Content="Export LAN party list" Command="{x:Bind ViewModel.LanExportCommand}" Style="{StaticResource AppButtonStyle}" />
                <Button Content="Export LAN preset allowlist" Command="{x:Bind ViewModel.LanPresetExportCommand}" Style="{StaticResource AppButtonStyle}" />
                <Button Content="Start hybrid co-op session" Command="{x:Bind ViewModel.HybridSessionCommand}" Style="{StaticResource AppButtonStyle}" />
                <TextBlock Text="{x:Bind ViewModel.V2StatusText, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.7" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
