<Page
    x:Class="SpatialLabsOptimizer.Views.ToolchainHealthView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:SpatialLabsOptimizer.Views"
    x:DataType="views:ToolchainHealthView">
    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="640">
            <TextBlock Text="Toolchain Health" FontSize="28" FontWeight="SemiBold" />
            <TextBlock Text="Smoke-test installed tools. Configure trainer and mod manager coexistence and launch safety." TextWrapping="Wrap" Opacity="0.8" />
            <ToggleSwitch Header="Safe launch (no injectors)" OffContent="Off" OnContent="On" IsOn="{x:Bind ViewModel.SafeLaunch, Mode=TwoWay}" />
            <ToggleSwitch Header="I use game trainers (WeMod, Wand, etc.)" OffContent="Off" OnContent="On" IsOn="{x:Bind ViewModel.TrainerCoexistence, Mode=TwoWay}" />
            <ToggleSwitch Header="I use a mod manager (Vortex, Mod Organizer)" OffContent="Off" OnContent="On" IsOn="{x:Bind ViewModel.ModManagerCoexistence, Mode=TwoWay}" />
            <ToggleSwitch Header="Simple mode UI" OffContent="Off" OnContent="On" IsOn="{x:Bind ViewModel.SimpleMode, Mode=TwoWay}" />
            <TextBlock Text="{x:Bind ViewModel.DetectedToolsText, Mode=OneWay}" Opacity="0.7" TextWrapping="Wrap" FontSize="12" />
            <TextBlock Text="Trainer ToS: You are responsible for complying with trainer provider terms." Opacity="0.7" TextWrapping="Wrap" FontSize="12" />
            <Button Content="Run health check" Command="{x:Bind ViewModel.RefreshDetectedToolsCommand}" Style="{StaticResource AppButtonStyle}" />
        </StackPanel>
    </ScrollViewer>
</Page>
