<Page
    x:Class="SpatialLabsOptimizer.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SpatialLabsOptimizer.Controls"
    xmlns:views="using:SpatialLabsOptimizer.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Background="{StaticResource Brush.Surface}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <controls:ShellActivityInfoBar
            Grid.Row="0"
            Message="{x:Bind ViewModel.ActivityMessage, Mode=OneWay}"
            IsOpen="{x:Bind ViewModel.ShowActivityBar, Mode=OneWay}"
            Progress="{x:Bind ViewModel.ActivityProgress, Mode=OneWay}" />

        <InfoBar
            Grid.Row="0"
            x:Name="DisplayChangeInfoBar"
            Margin="0,48,0,0"
            Severity="Warning"
            Title="Display changed"
            Message="{x:Bind ViewModel.DisplayChangeMessage, Mode=OneWay}"
            IsOpen="{x:Bind ViewModel.ShowDisplayChangePrompt, Mode=OneWay}"
            IsClosable="True"
            Closed="DisplayChangeInfoBar_Closed">
            <InfoBar.ActionButton>
                <Button Content="Open toolchain settings" Click="DisplayChangeRerun_Click" Style="{StaticResource AppButtonStyle}" />
            </InfoBar.ActionButton>
        </InfoBar>

        <InfoBar
            Grid.Row="0"
            x:Name="UpdateAvailableInfoBar"
            Margin="0,48,0,0"
            Severity="Informational"
            Title="Update available"
            Message="A newer version is ready to install."
            IsOpen="{x:Bind ViewModel.UpdateAvailable, Mode=OneWay}"
            IsClosable="True">
            <InfoBar.ActionButton>
                <Button Content="View in About" Click="UpdateAvailable_Click" Style="{StaticResource AppButtonStyle}" />
            </InfoBar.ActionButton>
        </InfoBar>

        <NavigationView
            Grid.Row="1"
            x:Name="NavView"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            KeyDown="NavView_KeyDown"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Library" Tag="library">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Library" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Settings" Tag="settings">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Manage" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Library Settings" Tag="library-settings">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="OpenLocal" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Quick Actions" Tag="commands">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Find" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Troubleshooting" Tag="troubleshoot">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Help" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Glossary" Tag="glossary">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Bookmarks" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="About" Tag="about">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="ContactInfo" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.PaneFooter>
                <TextBlock
                    Text="{x:Bind ViewModel.VersionLabel, Mode=OneWay}"
                    Margin="12,8"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Left"
                    FontSize="12"
                    Opacity="0.65" />
            </NavigationView.PaneFooter>
            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <Grid Grid.Row="2" Padding="12,8" Background="{StaticResource Brush.SurfaceAlt}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}" VerticalAlignment="Center" Opacity="0.8" />
            <Border
                Grid.Column="1"
                Background="{StaticResource Brush.Accent}"
                CornerRadius="12"
                Padding="10,4"
                ToolTipService.ToolTip="Background activity status">
                <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}" FontSize="12" />
            </Border>
        </Grid>

        <controls:LaunchProgressOverlay
            Grid.RowSpan="3"
            GameTitle="{x:Bind ViewModel.LaunchGameTitle, Mode=OneWay}"
            CurrentStep="{x:Bind ViewModel.LaunchStep, Mode=OneWay}"
            ProgressPercent="{x:Bind ViewModel.LaunchProgressPercent, Mode=OneWay}"
            IsOpen="{x:Bind ViewModel.ShowLaunchOverlay, Mode=OneWay}" />
    </Grid>
</Page>
