<Page
    x:Class="SpatialLabsOptimizer.Views.CommandPaletteView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBox x:Name="SearchBox"
                 AutomationProperties.AutomationId="CommandPalette_Search"
                 PlaceholderText="Search commands…"
                 TextChanged="SearchBox_TextChanged" />
        <ListView x:Name="ResultsList" Grid.Row="1" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="ResultsList_ItemClick" />
    </Grid>
</Page>
